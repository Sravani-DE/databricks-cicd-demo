   "source": [
    "%sql\n",
    "CREATE OR REPLACE TEMP VIEW trip_summary AS\n",
    "SELECT\n",
    " pickup_zip,\n",
    " COUNT(*) AS total_trips\n",
    "FROM samples.nyctaxi.trips\n",
    "GROUP BY pickup_zip;\n",
    "SELECT *\n",
    "FROM trip_summary\n",
    "ORDER BY total_trips DESC\n",
    "LIMIT 10;"
   ]
  }
